{
  "name": "agentflyer",
  "version": "1.1.0",
  "description": "Distributed AgentOS for multi-agent orchestration, workflows, memory, and multi-channel AI runtimes",
  "type": "module",
  "license": "MIT",
  "author": "dteric",
  "repository": {
    "type": "git",
    "url": "https://github.com/tddt/AgentFlyer.git"
  },
  "homepage": "https://github.com/tddt/AgentFlyer#readme",
  "bugs": {
    "url": "https://github.com/tddt/AgentFlyer/issues"
  },
  "keywords": [
    "agentos",
    "ai",
    "agent",
    "multi-agent",
    "workflow",
    "orchestration",
    "mcp",
    "sandbox",
    "memory",
    "automation",
    "multi-channel",
    "bun",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md",
    "README_CN.md",
    "LICENSE"
  ],
  "bin": {
    "agentflyer": "./dist/cli/main.js"
  },
  "exports": {
    "./agent/process-runtime": "./dist/agent/process-runtime.js",
    "./memory": "./dist/memory/index.js",
    "./skills": "./dist/skills/index.js",
    "./scheduler": "./dist/scheduler/index.js",
    "./mesh": "./dist/mesh/index.js",
    "./federation": "./dist/federation/index.js",
    "./gateway": "./dist/gateway/index.js",
    "./channels": "./dist/channels/index.js"
  },
  "scripts": {
    "dev": "bun run src/cli/main.ts",
    "dev:start": "bun run src/cli/main.ts start --force",
    "dev:chat": "bun run src/cli/main.ts chat",
    "build": "tsc --project tsconfig.build.json && pnpm console:build && node scripts/copy-console.mjs",
    "typecheck": "tsc --noEmit",
    "check": "biome check src/ tests/",
    "check:fix": "biome check --write src/ tests/",
    "test": "bun vitest run",
    "test:watch": "bun vitest",
    "test:coverage": "bun vitest run --coverage",
    "start": "node dist/cli/main.js start",
    "chat": "node dist/cli/main.js chat",
    "console:build": "cd src/gateway/console-ui && bun run build",
    "console:dev": "cd src/gateway/console-ui && bun run dev",
    "prepublishOnly": "pnpm build && pnpm check && pnpm test",
    "publish:npm": "node scripts/publish-npm.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clack/prompts": "^0.9.0",
    "@huggingface/transformers": "^3.4.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@noble/ciphers": "^1.3.0",
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.2",
    "better-sqlite3": "^11.9.1",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "citty": "^0.1.6",
    "croner": "^9.0.0",
    "gray-matter": "^4.0.3",
    "json5": "^2.2.3",
    "openai": "^4.89.0",
    "sqlite-vec": "^0.1.6",
    "tiktoken": "^1.0.21",
    "ulid": "^2.3.0",
    "multicast-dns": "^7.2.5",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.14",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^3.0.9",
    "msw": "^2.7.3",
    "sql.js": "^1.14.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
